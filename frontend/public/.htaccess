<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct HTTP access to PHP backend files stored next to the SPA (cPanel layout).
  RewriteRule ^(bootstrap|config)\.php$ - [F,L]
  RewriteRule ^(src|database)(/|$) - [F,L]

  # SEO: /sitemap.xml is generated by PHP (blog + portfolio URLs). Run before the -f rule so a
  # stale static sitemap.xml on disk cannot override the dynamic sitemap.
  RewriteRule ^sitemap\.xml$ /api/public/sitemap.xml [L]

  # Older admin uploads stored image_url as /uploads/... — files actually live in api/uploads/.
  RewriteRule ^uploads/(.*)$ /api/uploads/$1 [L]

  # Admin UI is React Router (no real /admin files). If public_html/admin exists as an empty folder,
  # LiteSpeed would 404 here — always serve the SPA shell first.
  RewriteRule ^admin(?:/.*)?$ /index.html [L]

  # If the request targets an existing file/folder, serve it directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # PHP API: URIs like /api/public/... are NOT real folders under public_html/api/ (only index.php, uploads, …).
  # Without this rule, LiteSpeed/Apache returns 404 before PHP runs. Route non-files to api/index.php.
  RewriteCond %{REQUEST_URI} ^/api(/|$)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^api(?:$|/)(.*)$ api/index.php [L,QSA]

  # SPA fallback for React Router routes.
  RewriteRule ^ index.html [L]
</IfModule>


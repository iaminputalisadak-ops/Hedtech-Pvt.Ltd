# Copy to tunnel.env (gitignored). Used by: npm run tunnel:mysql
# cPanel MySQL usually listens only on 127.0.0.1 on the server — this SSH tunnel exposes it locally.

SSH_HOST=your-server.example.com
SSH_USER=your_cpanel_ssh_username
SSH_PORT=22
# Path to private key (OpenSSH). Leave empty to use default ~/.ssh keys + ssh-agent.
SSH_KEY=

# Local port on your PC (pick a free port, e.g. 13307)
LOCAL_PORT=13307
# On the server, MySQL almost always is:
REMOTE_DB_HOST=127.0.0.1
REMOTE_DB_PORT=3306

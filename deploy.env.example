# Copy this file to deploy.env in the project root (deploy.env is gitignored).
# Then run: npm run deploy:cpanel
#
# Use the same values as cPanel → FTP Accounts (or your host’s FTP instructions).

HEDZTECH_FTP_HOST=ftp.example.com
HEDZTECH_FTP_PORT=21
HEDZTECH_FTP_USER=your_ftp_username
HEDZTECH_FTP_PASS=your_ftp_password
# Absolute path on the server to your site root (often public_html or the FTP account’s home).
HEDZTECH_FTP_REMOTE=/home/username/public_html
# true = FTP over TLS (FTPS explicit on port 21). false = plain FTP (not recommended).
HEDZTECH_FTP_SECURE=true
